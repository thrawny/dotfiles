#!/usr/bin/env bash

[[ "${TRACE}" ]] && set -x
set -euo pipefail

error() {
  echo "Error: $*" >&2
  exit 1
}

show_usage() {
  echo "Usage: niri-project [--name NAME] [directory]"
  echo ""
  echo "Create a niri workspace for a project with a terminal."
  echo "Workspace name is derived from the directory basename unless overridden."
  echo ""
  echo "Options:"
  echo "  --name NAME  Override the workspace name"
  echo "  -h, --help   Show this help"
  echo ""
  echo "Arguments:"
  echo "  directory    Project directory (default: current directory)"
  echo ""
  echo "Examples:"
  echo "  niri-project                     # Use current directory"
  echo "  niri-project ~/code/myapp        # Use specified directory"
  echo "  niri-project --name foo          # Override workspace name"
  echo "  niri-project --name foo ~/code/myapp"
}

main() {
  local workspace_name=""
  local project_dir="$PWD"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)
        show_usage
        exit 0
        ;;
      --name)
        [[ $# -ge 2 ]] || error "Missing value for --name"
        workspace_name="$2"
        shift 2
        ;;
      --)
        shift
        break
        ;;
      -*)
        error "Unknown option: $1"
        ;;
      *)
        [[ "$project_dir" == "$PWD" ]] || error "Only one directory argument is supported"
        project_dir="$1"
        shift
        ;;
    esac
  done

  if [[ $# -gt 0 ]]; then
    [[ "$project_dir" == "$PWD" ]] || error "Only one directory argument is supported"
    project_dir="$1"
    shift
  fi

  [[ $# -eq 0 ]] || error "Unexpected arguments: $*"

  project_dir=$(cd "$project_dir" && pwd)

  if [[ ! -d "$project_dir" ]]; then
    error "Directory does not exist: $project_dir"
  fi

  if [[ -z "$workspace_name" ]]; then
    workspace_name=$(basename "$project_dir")
  fi

  # If workspace already exists, just focus it
  if niri msg -j workspaces | jq -e ".[] | select(.name == \"$workspace_name\")" >/dev/null 2>&1; then
    niri msg action focus-workspace "$workspace_name"
    exit 0
  fi

  # Get the focused monitor
  local focused_output
  focused_output=$(niri msg -j workspaces | jq -r '.[] | select(.is_focused) | .output')

  # Prefer project workspaces before ad-hoc/numeric session workspaces on this monitor.
  # agent-switch sessions are unnamed workspaces; numeric keybinds address them by idx.
  local workspaces_json first_session_idx target_idx insert_before_idx=""
  workspaces_json=$(niri msg -j workspaces)
  first_session_idx=$(jq -r --arg output "$focused_output" \
    '[.[] | select(.output == $output and (((.name // "") | test("^[0-9]")) or (.name == null and .active_window_id != null))) | .idx] | min // empty' \
    <<<"$workspaces_json")

  if [[ -n "$first_session_idx" ]]; then
    # Reuse the closest empty workspace before sessions start.
    target_idx=$(jq -r --arg output "$focused_output" --argjson before "$first_session_idx" \
      '[.[] | select(.output == $output and .idx < $before and .name == null and .active_window_id == null) | .idx] | max // empty' \
      <<<"$workspaces_json")
  else
    # Otherwise use the trailing empty workspace on this monitor.
    target_idx=$(jq -r --arg output "$focused_output" \
      '[.[] | select(.output == $output and .name == null and .active_window_id == null) | .idx] | max // empty' \
      <<<"$workspaces_json")
  fi

  if [[ -n "$target_idx" ]]; then
    niri msg action focus-workspace "$target_idx"
  else
    # No empty workspace available in the right place — create one at the end.
    local last_idx
    last_idx=$(jq -r --arg output "$focused_output" \
      '[.[] | select(.output == $output) | .idx] | max' \
      <<<"$workspaces_json")
    niri msg action focus-workspace "$last_idx"
    niri msg action focus-workspace-down

    if [[ -n "$first_session_idx" ]]; then
      insert_before_idx="$first_session_idx"
    fi
  fi

  # Name the workspace, optionally move it before sessions, and spawn a terminal.
  niri msg action set-workspace-name "$workspace_name"
  if [[ -n "$insert_before_idx" ]]; then
    niri msg action move-workspace-to-index "$insert_before_idx"
  fi
  niri msg action spawn -- ghostty --working-directory="$project_dir"
}

main "$@"
