#!/usr/bin/env bun
// @ts-nocheck

import { existsSync, readFileSync, statSync } from "node:fs";
import { basename, extname, resolve } from "node:path";

const DEFAULT_URL = "https://drops.lakebed.app";
const TEXT_CHUNK_CHARS = 700_000;
const BASE64_CHUNK_BYTES = 540_000; // multiple of 3 for clean base64 boundaries
const SINGLE_POST_MAX_CHARS = 700_000;

function usage() {
  console.log(`share-html — publish a static HTML file to Drops (${DEFAULT_URL})

Usage:
  share-html [--slug SLUG] [--title TITLE] [--token TOKEN] [--url URL] [--base64] [--dry-run] FILE

What it does:
  - publishes FILE to the Drops app as a public bearer-link page
  - derives the title from the HTML <title> and a slug from it (or the filename)
  - prints the public Drops URL: <url>/s/<token>/<slug>/
  - viewers can select text on the page and leave inline comment threads
  - large files are uploaded in chunks automatically

Options:
  --slug SLUG    Override slug (default: from <title>, else filename)
  --title TITLE  Override title (default: from the HTML <title>)
  --token TOKEN  Use a specific bearer token (>=6 URL-safe chars; default: server-generated)
  --url URL      Drops base URL (default: \$DROPS_URL or ${DEFAULT_URL})
  --base64       Byte-safe chunked upload for very large or unusual files
  --dry-run      Print what would be uploaded without publishing
  -h, --help     Show this help

Environment:
  DROPS_URL overrides the default Drops base URL.

Examples:
  share-html lab/report.html
  share-html --slug sinexcel-modbus-infographic lab/sinexcel-modbus-infographic.html`);
}

const args = Bun.argv.slice(2);
let baseUrl = process.env.DROPS_URL || DEFAULT_URL;
let slug = null;
let title = null;
let token = null;
let useBase64 = false;
let dryRun = false;
let fileArg = null;

for (let i = 0; i < args.length; i += 1) {
  const arg = args[i];
  switch (arg) {
    case "-h":
    case "--help":
      usage();
      process.exit(0);
    case "--url":
    case "--domain":
      baseUrl = requireValue(args, ++i, arg);
      break;
    case "--slug":
      slug = requireValue(args, ++i, arg);
      break;
    case "--title":
      title = requireValue(args, ++i, arg);
      break;
    case "--token":
      token = requireValue(args, ++i, arg);
      break;
    case "--base64":
      useBase64 = true;
      break;
    case "--dry-run":
      dryRun = true;
      break;
    default:
      if (arg.startsWith("-")) {
        console.error(`share-html: unknown option: ${arg}`);
        usage();
        process.exit(2);
      }
      if (fileArg) {
        console.error(`share-html: unexpected argument: ${arg}`);
        usage();
        process.exit(2);
      }
      fileArg = arg;
  }
}

if (!fileArg) {
  usage();
  process.exit(2);
}

const file = resolve(fileArg);
try {
  if (!statSync(file).isFile()) throw new Error("not a file");
} catch (err) {
  console.error(`share-html: cannot read ${file}: ${err.message}`);
  process.exit(1);
}
if (!existsSync(file)) {
  console.error(`share-html: file does not exist: ${file}`);
  process.exit(1);
}

baseUrl = baseUrl.replace(/\/+$/, "");

if (token && !/^[a-zA-Z0-9_-]{6,}$/.test(token)) {
  console.error("share-html: --token must be at least 6 URL-safe characters: A-Z a-z 0-9 _ -");
  process.exit(1);
}

const html = readFileSync(file, "utf8");
if (!html.trim()) {
  console.error(`share-html: ${file} is empty`);
  process.exit(1);
}
if (!title) title = titleFromHtml(html);
if (!slug) slug = slugify(title ?? basename(file, extname(file)));
if (!slug) {
  console.error("share-html: slug is empty after normalization; pass --slug");
  process.exit(1);
}

const chunked = useBase64 || html.length > SINGLE_POST_MAX_CHARS;

console.log(`file:  ${file}`);
console.log(`drops: ${baseUrl}`);
console.log(`slug:  ${slug}`);
if (title) console.log(`title: ${title}`);
console.log(`mode:  ${chunked ? (useBase64 ? "chunked (base64)" : "chunked (text)") : "single"}`);

if (dryRun) process.exit(0);

const result = chunked ? await uploadChunked() : await uploadSingle();
const path =
  result.path || (result.url ? new URL(result.url).pathname : null);
if (!path) {
  fail(`upload did not return a path: ${JSON.stringify(result)}`);
}

console.log("");
console.log(`${baseUrl}${path}`);

async function uploadSingle() {
  const body = { html, slug };
  if (title) body.title = title;
  if (token) body.token = token;
  return postJson(`${baseUrl}/api/drops`, body);
}

async function uploadChunked() {
  const startBody = { encoding: useBase64 ? "base64" : "text", slug };
  if (title) startBody.title = title;
  if (token) startBody.token = token;

  const start = await postJson(`${baseUrl}/api/drop-uploads`, startBody);
  const uploadId = start.uploadId;
  if (!uploadId) {
    fail(`upload did not return an uploadId: ${JSON.stringify(start)}`);
  }

  if (useBase64) {
    const bytes = readFileSync(file);
    for (let offset = 0, index = 0; offset < bytes.length; offset += BASE64_CHUNK_BYTES, index += 1) {
      const end = Math.min(offset + BASE64_CHUNK_BYTES, bytes.length);
      const chunk = bytes.subarray(offset, end).toString("base64");
      await postJson(`${baseUrl}/api/drop-upload-chunks`, { chunk, index, uploadId });
      progress(end, bytes.length);
    }
  } else {
    for (let offset = 0, index = 0; offset < html.length; offset += TEXT_CHUNK_CHARS, index += 1) {
      const end = Math.min(offset + TEXT_CHUNK_CHARS, html.length);
      const chunk = html.slice(offset, end);
      await postJson(`${baseUrl}/api/drop-upload-chunks`, { chunk, index, uploadId });
      progress(end, html.length);
    }
  }

  return postJson(`${baseUrl}/api/drop-upload-finish`, { uploadId });
}

async function postJson(url, body) {
  const response = await fetch(url, {
    method: "POST",
    headers: { "content-type": "application/json" },
    body: JSON.stringify(body),
  });
  const raw = await response.text();
  let payload = null;
  try {
    payload = raw ? JSON.parse(raw) : null;
  } catch {
    payload = { body: raw };
  }
  if (!response.ok) {
    fail(`${url} failed with ${response.status}: ${JSON.stringify(payload)}`);
  }
  return payload;
}

function requireValue(args, index, option) {
  const value = args[index];
  if (!value || value.startsWith("-")) {
    console.error(`share-html: ${option} requires a value`);
    process.exit(2);
  }
  return value;
}

function titleFromHtml(text) {
  const match = text.slice(0, 200_000).match(/<title[^>]*>([\s\S]*?)<\/title>/i);
  if (!match) return null;
  return decodeHtml(match[1].replace(/<[^>]*>/g, " ").replace(/\s+/g, " ").trim()) || null;
}

function decodeHtml(text) {
  return text
    .replace(/&amp;/g, "&")
    .replace(/&lt;/g, "<")
    .replace(/&gt;/g, ">")
    .replace(/&quot;/g, '"')
    .replace(/&#39;/g, "'")
    .replace(/&apos;/g, "'");
}

function slugify(text) {
  return text
    .normalize("NFKD")
    .replace(/[̀-ͯ]/g, "")
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "")
    .slice(0, 80)
    .replace(/-+$/g, "");
}

function progress(sent, total) {
  const percent = total === 0 ? 100 : Math.floor((sent / total) * 100);
  process.stderr.write(`\ruploaded ${percent}%`);
}

function fail(message) {
  console.error(`share-html: ${message}`);
  process.exit(1);
}
