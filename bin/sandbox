#!/usr/bin/env bash
set -euo pipefail

sandbox() {
  local tmpfiles=() args=()
  local sandbox_zmx_dir=/tmp/zmx
  local default_zmx_dir

  if [[ -n "${XDG_RUNTIME_DIR:-}" ]]; then
    default_zmx_dir="${XDG_RUNTIME_DIR%/}/zmx"
  elif [[ -n "${TMPDIR:-}" ]]; then
    default_zmx_dir="${TMPDIR%/}/zmx"
  else
    default_zmx_dir=/tmp/zmx
  fi

  # Redact .secrets files (show keys, hide values)
  while IFS= read -r -d '' f; do
    local tmp
    tmp=$(mktemp)
    sed 's/=.*/="REDACTED"/' "$f" > "$tmp"
    args+=(--ro-bind "$tmp" "$f")
    tmpfiles+=("$tmp")
  done < <(fd -H -g '.secrets' ~ --type f -0 2>/dev/null)

  # Writable paths (add more as needed)
  local writable=(
    ~/.cache
    ~/.local
    ~/.codex
    ~/.claude.json
    ~/.claude
    ~/.pi
    ~/.zsh_history
    ~/dotfiles
    ~/code
    /run/user/${UID}
  )
  for d in "${writable[@]}"; do
    d="${d/#\~/$HOME}"
    [[ -e "$d" ]] && args+=(--bind "$d" "$d")
  done

  # Give each sandbox its own zmx namespace and hide host control sockets.
  for d in "$default_zmx_dir" "${ZMX_DIR:-}"; do
    [[ -n "$d" ]] || continue
    d="${d/#\~/$HOME}"
    [[ "$d" == "$sandbox_zmx_dir" ]] && continue
    args+=(--tmpfs "$d")
  done

  # work/*/code and work/*/.direnv directories
  for d in ~/work/*/code ~/work/*/.direnv; do
    [[ -d "$d" ]] && args+=(--bind "$d" "$d")
  done

  # Deny access to sensitive paths (applied after writable to override)
  local deny=(
    ~/.ssh
    ~/.gnupg
    ~/.aws
    ~/.config/gh
    ~/.kube
  )
  for d in "${deny[@]}"; do
    d="${d/#\~/$HOME}"
    [[ -e "$d" ]] || continue
    if [[ -d "$d" ]]; then
      args+=(--tmpfs "$d")
    else
      args+=(--bind /dev/null "$d")
    fi
  done

  # Block nested .aws dirs in work projects
  for d in ~/work/*/.aws; do
    [[ -d "$d" ]] && args+=(--tmpfs "$d")
  done

  bwrap \
    --ro-bind / / \
    --bind "${PWD}" "${PWD}" \
    --tmpfs /tmp \
    --dev /dev \
    --proc /proc \
    --die-with-parent \
    --setenv ZMX_DIR "$sandbox_zmx_dir" \
    "${args[@]}" \
    -- "$@"

  rm -f "${tmpfiles[@]}"
}

sandbox "$@"
