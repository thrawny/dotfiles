#!/usr/bin/env bash
{
set -euo pipefail

sandbox() {
  local tmpfiles=() args=() extra=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --) shift; break ;;
      -*) extra+=("$1"); shift ;;
      *) break ;;
    esac
  done

  # Writable paths (add more as needed)
  local writable=(
    ~/.cache
    ~/go
    ~/.local
    ~/.bun/install/cache
    ~/.codex
    ~/.claude
    ~/.pi
    ~/.npm
    ~/.zsh_history
    ~/dotfiles
    ~/code
  )
  for d in "${writable[@]}"; do
    d="${d/#\~/$HOME}"
    [[ -e "$d" ]] && args+=(--bind "$d" "$d")
  done

  # Hide host runtime sockets and give the sandbox its own empty runtime dir.
  if [[ -d "/run/user/${UID}" ]]; then
    args+=(--tmpfs "/run/user/${UID}")
    args+=(
      --ro-bind-try
      "/run/user/${UID}/agent-switch.sock"
      "/run/user/${UID}/agent-switch.sock"
    )

    # Expose Wayland socket so wl-paste (used by pi/claude for image paste) works
    if [[ -n "${WAYLAND_DISPLAY:-}" ]]; then
      args+=(
        --ro-bind-try
        "/run/user/${UID}/${WAYLAND_DISPLAY}"
        "/run/user/${UID}/${WAYLAND_DISPLAY}"
      )
    fi

    # Expose D-Bus session socket so notify-send works
    args+=(
      --ro-bind-try
      "/run/user/${UID}/bus"
      "/run/user/${UID}/bus"
    )

    # Expose PipeWire/PulseAudio socket so paplay (notification sounds) works
    args+=(
      --ro-bind-try
      "/run/user/${UID}/pulse"
      "/run/user/${UID}/pulse"
    )
    args+=(
      --ro-bind-try
      "/run/user/${UID}/pipewire-0"
      "/run/user/${UID}/pipewire-0"
    )
  fi

  # Optionally create a dedicated SSH agent for a specific key.
  if [[ -n "${SANDBOX_SSH_KEY:-}" ]]; then
    local key="${SANDBOX_SSH_KEY/#\~/$HOME}"
    local runtime_dir="${XDG_RUNTIME_DIR:-/run/user/${UID}}"
    local key_id

    if resolved_key=$(realpath "$key" 2>/dev/null); then
      key="$resolved_key"
    fi
    key_id=$(printf '%s' "$key" | sha256sum | cut -d' ' -f1)

    [[ -d "$runtime_dir" ]] || {
      echo "sandbox: runtime dir not found: $runtime_dir" >&2
      exit 1
    }

    export SSH_AUTH_SOCK="$runtime_dir/sandbox-ssh-${key_id}.sock"

    if ! timeout 2 ssh-add -l >/dev/null 2>&1; then
      rm -f "$SSH_AUTH_SOCK"
      eval "$(ssh-agent -a "$SSH_AUTH_SOCK")" >/dev/null 2>&1
    fi

    timeout 5 ssh-add "$key" </dev/null 2>/dev/null || true
    export GIT_SSH_COMMAND="${GIT_SSH_COMMAND:-ssh -F /dev/null}"
  fi

  # Forward SSH agent socket so git can authenticate without exposing ~/.ssh
  if [[ -n "${SSH_AUTH_SOCK:-}" && -S "${SSH_AUTH_SOCK}" ]]; then
    args+=(--ro-bind "$SSH_AUTH_SOCK" "$SSH_AUTH_SOCK")
  fi

  # Expose Claude Code browser bridge socket for Chrome extension integration
  local bridge_dir="/tmp/claude-mcp-browser-bridge-${USER}"
  if [[ -d "$bridge_dir" ]]; then
    args+=(--bind "$bridge_dir" "$bridge_dir")
  fi

  # work/*/code and work/*/.direnv directories
  for d in ~/work/*/code ~/work/*/.direnv ~/work/*/bin; do
    [[ -d "$d" ]] && args+=(--bind "$d" "$d")
  done

  # Redact .secrets* files after writable binds so file-level mounts win.
  while IFS= read -r -d '' f; do
    local tmp
    tmp=$(mktemp)
    sed 's/=.*/="REDACTED"/' "$f" > "$tmp"
    args+=(--ro-bind "$tmp" "$f")
    tmpfiles+=("$tmp")
  done < <(fd -H -g '.secrets*' ~ --type f -0 2>/dev/null)

  # Deny access to sensitive paths (applied after writable to override)
  local deny=(
    ~/.ssh
    ~/.gnupg
    ~/.aws
    ~/.config/gh
    ~/.kube
  )
  for d in "${deny[@]}"; do
    d="${d/#\~/$HOME}"
    [[ -e "$d" ]] || continue
    if [[ -d "$d" ]]; then
      args+=(--tmpfs "$d")
    else
      args+=(--bind /dev/null "$d")
    fi
  done

  # Block nested .aws dirs in work projects
  for d in ~/work/*/.aws; do
    [[ -d "$d" ]] && args+=(--tmpfs "$d")
  done

  bwrap \
    --ro-bind / / \
    --bind "${PWD}" "${PWD}" \
    --tmpfs /tmp \
    --dev /dev \
    --proc /proc \
    --die-with-parent \
    --setenv SANDBOX 1 \
    "${args[@]}" \
    "${extra[@]}" \
    -- "$@"

  rm -f "${tmpfiles[@]}"
}

sandbox "$@"
exit
}
