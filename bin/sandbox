#!/usr/bin/env bash
set -euo pipefail

sandbox() {
  local tmpfiles=() args=()

  # Redact .secrets files (show keys, hide values)
  while IFS= read -r -d '' f; do
    local tmp
    tmp=$(mktemp)
    sed 's/=.*/="REDACTED"/' "$f" > "$tmp"
    args+=(--ro-bind "$tmp" "$f")
    tmpfiles+=("$tmp")
  done < <(fd -H -g '.secrets' ~ --type f -0 2>/dev/null)

  # Writable paths (add more as needed)
  local writable=(
    ~/.cache
    ~/.local
    ~/.codex
    ~/.claude.json
    ~/.claude
    ~/.pi
    ~/.zsh_history
    ~/dotfiles
    ~/code
  )
  for d in "${writable[@]}"; do
    d="${d/#\~/$HOME}"
    [[ -e "$d" ]] && args+=(--bind "$d" "$d")
  done

  # Hide host runtime sockets and give the sandbox its own empty runtime dir.
  [[ -d "/run/user/${UID}" ]] && args+=(--tmpfs "/run/user/${UID}")

  # work/*/code and work/*/.direnv directories
  for d in ~/work/*/code ~/work/*/.direnv; do
    [[ -d "$d" ]] && args+=(--bind "$d" "$d")
  done

  # Deny access to sensitive paths (applied after writable to override)
  local deny=(
    ~/.ssh
    ~/.gnupg
    ~/.aws
    ~/.config/gh
    ~/.kube
  )
  for d in "${deny[@]}"; do
    d="${d/#\~/$HOME}"
    [[ -e "$d" ]] || continue
    if [[ -d "$d" ]]; then
      args+=(--tmpfs "$d")
    else
      args+=(--bind /dev/null "$d")
    fi
  done

  # Block nested .aws dirs in work projects
  for d in ~/work/*/.aws; do
    [[ -d "$d" ]] && args+=(--tmpfs "$d")
  done

  bwrap \
    --ro-bind / / \
    --bind "${PWD}" "${PWD}" \
    --tmpfs /tmp \
    --dev /dev \
    --proc /proc \
    --die-with-parent \
    "${args[@]}" \
    -- "$@"

  rm -f "${tmpfiles[@]}"
}

sandbox "$@"
