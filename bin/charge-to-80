#!/usr/bin/env bash
set -euo pipefail

bat="${1:-BAT0}"
target=80
start=$((target - 1))
log="${XDG_STATE_HOME:-$HOME/.local/state}/charge-to-80.log"
mkdir -p "$(dirname "$log")"

sysfs="/sys/class/power_supply/$bat"
if [ ! -d "$sysfs" ]; then
  echo "Battery not found: $bat" >&2
  exit 1
fi

orig_start=$(cat "$sysfs/charge_control_start_threshold")
orig_stop=$(cat "$sysfs/charge_control_end_threshold")

# Prompt once now, then launch the privileged monitor in the background.
sudo -v
sudo -n bash -c '
  set -euo pipefail
  bat="$1"
  target="$2"
  start="$3"
  orig_start="$4"
  orig_stop="$5"
  log="$6"
  sysfs="/sys/class/power_supply/$bat"

  echo "$(date -Is) setting $bat thresholds to $start-$target (was $orig_start-$orig_stop)" >> "$log"
  tlp setcharge "$start" "$target" "$bat" >> "$log" 2>&1

  while [ "$(cat "$sysfs/capacity")" -lt "$target" ]; do
    if [ "$(cat /sys/class/power_supply/AC/online 2>/dev/null || echo 0)" != "1" ]; then
      echo "$(date -Is) AC unplugged; restoring thresholds" >> "$log"
      break
    fi
    sleep 60
  done

  echo "$(date -Is) restoring $bat thresholds to $orig_start-$orig_stop" >> "$log"
  tlp setcharge "$orig_start" "$orig_stop" "$bat" >> "$log" 2>&1
' bash "$bat" "$target" "$start" "$orig_start" "$orig_stop" "$log" </dev/null >/dev/null 2>&1 &

echo "Charging $bat to $target%, then restoring $orig_start-$orig_stop in background."
echo "Log: $log"
