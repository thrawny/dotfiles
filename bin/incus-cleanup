#!/usr/bin/env bash

[[ "${TRACE:-}" ]] && set -x
set -euo pipefail
shopt -s nullglob

main() {
  local container="headless"
  local user="thrawny"
  local archive_dir="$HOME/.local/share/incus-cleanup"
  local keep=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --keep)
        keep=true
        ;;
      --output)
        archive_dir="$2"
        shift
        ;;
      --user)
        user="$2"
        shift
        ;;
      --help|-h)
        usage
        return 0
        ;;
      *)
        container="$1"
        ;;
    esac
    shift
  done

  local home
  if [[ "$user" == "root" ]]; then
    home="/root"
  else
    home="/home/$user"
  fi

  incus info "$container" >/dev/null

  # Ensure the container is running so we can exec into it
  local was_stopped=false
  if ! incus exec "$container" -- true 2>/dev/null; then
    was_stopped=true
    incus start "$container"
    echo "Started container '$container' for archiving."
  fi

  local timestamp
  timestamp="$(date -u +%Y%m%dT%H%M%SZ)"
  local safe_container="${container//:/_}"
  local archive_name="${safe_container}-${timestamp}"
  local staging_dir
  staging_dir="$(mktemp -d)"
  # shellcheck disable=SC2064
  trap "rm -rf '$staging_dir'" EXIT

  echo "Archiving home directory from container '$container'..."
  archive_home "$container" "$home" "$staging_dir"

  mkdir -p "$archive_dir"
  local archive_path="$archive_dir/${archive_name}.tar.gz"

  if [[ -z "$(ls -A "$staging_dir")" ]]; then
    echo "Nothing to archive."
  else
    tar -C "$staging_dir" -czf "$archive_path" .
    echo "Archive: $archive_path"
  fi

  if [[ "$keep" == true ]]; then
    echo "Keeping container '$container' (stopped)."
    incus stop "$container" --force 2>/dev/null || true
  else
    echo "Deleting container '$container'..."
    incus delete "$container" --force
    echo "Deleted."
  fi
}

usage() {
  cat <<'EOF'
Usage: incus-cleanup [options] [container]

Archives the user's home directory from an Incus container, then deletes it.

Arguments:
  container     Container name (default: headless)

Options:
  --keep        Stop the container instead of deleting it
  --output DIR  Archive destination (default: ~/.local/share/incus-cleanup)
  --user USER   Container user (default: thrawny)

The archive contains:
  home/        Full copy of the container user's home directory, excluding known
               large generated directories: ~/.local/share/nvim, node_modules,
               and .venv directories

Examples:
  incus-cleanup headless
  incus-cleanup --keep builder:dev
  incus-cleanup --output /tmp/archives my-container
EOF
}

archive_home() {
  local container="$1" home="$2" staging_dir="$3"

  mkdir -p "$staging_dir/home"

  incus exec "$container" -- tar \
    --exclude="$(basename "$home")/.local/share/nvim" \
    --exclude='*/node_modules' \
    --exclude='*/node_modules/*' \
    --exclude='*/.venv' \
    --exclude='*/.venv/*' \
    -C "$(dirname "$home")" \
    -cf - \
    -- "$(basename "$home")" \
    | tar -C "$staging_dir/home" --strip-components=1 -xf -

  echo "  Copied $home, excluding ~/.local/share/nvim, node_modules, and .venv."
}


main "$@"
