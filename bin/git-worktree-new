#!/usr/bin/env bash

[[ "${TRACE}" ]] && set -x
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: git-worktree-new <branch> [git worktree add args...]" >&2
  exit 1
fi

branch="$1"; shift
root=$(git rev-parse --show-toplevel)
repo=$(basename "$root")
wt_dir="${root}/../${repo}-worktrees/${branch}"

if [[ ! -d "$wt_dir" ]]; then
  if git show-ref --verify --quiet "refs/heads/$branch"; then
    git worktree add "$wt_dir" "$branch" "$@"
  else
    git worktree add -b "$branch" "$wt_dir" "$@"
  fi
fi

while IFS= read -r -d '' src; do
  f="${src#"${root}/"}"
  mkdir -p "$(dirname "${wt_dir}/${f}")"
  cp "${src}" "${wt_dir}/${f}"
done < <(fd -H -I -0 -t f -E .git '^\.(env|env\..*|envrc|envrc\..*|secrets.*)$' "$root")

for f in .claude/settings.local.json; do
  if [[ -f "${root}/${f}" ]]; then
    mkdir -p "$(dirname "${wt_dir}/${f}")"
    cp "${root}/${f}" "${wt_dir}/${f}"
  fi
done

niri-project --terminals 1 "$wt_dir"
