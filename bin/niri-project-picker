#!/usr/bin/env bash

[[ "${TRACE}" ]] && set -x
set -euo pipefail

projects=$({
  zoxide query -l | while read -r d; do
    git -C "$d" rev-parse --show-toplevel 2>/dev/null || true
  done
  find ~/code ~/work/*/code -maxdepth 3 -name .git 2>/dev/null | while read -r g; do
    printf '%s\n' "${g%/.git}"
  done
} | awk '!seen[$0]++')

set +e
output=$(fzf --prompt="project> " --height=100% --header="Esc to type a path" --expect=esc <<< "$projects")
rc=$?
set -e

key=$(head -1 <<< "$output")
dir=$(sed -n '2p' <<< "$output")

if [[ "$key" == "esc" ]]; then
  read -rep "path> " dir || exit 0
  [[ -n "$dir" ]] && dir=$(eval echo "$dir")
elif [[ $rc -ne 0 ]]; then
  exit 0
fi

[[ -n "${dir:-}" ]] && niri-project "$dir"
