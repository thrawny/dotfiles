#!/usr/bin/env bash

[[ "${TRACE:-}" ]] && set -x
set -euo pipefail
shopt -s nullglob

main() {
  local container=""
  local remote="local"
  local user="thrawny"
  local prepare=true
  local mode="copy"
  local github_token=""
  local repo_url=""
  local repo_path=""
  local session_scope="repo"
  local session_scope_explicit=false
  local -a extra_packages=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --remote)
        remote="$2"
        shift
        ;;
      --no-prepare)
        prepare=false
        ;;
      --mount-rw)
        mode="mount"
        ;;
      --copy)
        mode="copy"
        ;;
      --no-sessions)
        session_scope="none"
        session_scope_explicit=true
        ;;
      --repo-sessions)
        session_scope="repo"
        session_scope_explicit=true
        ;;
      --all-sessions)
        session_scope="all"
        session_scope_explicit=true
        ;;
      --path)
        repo_path="$(resolve_host_path "$2")"
        shift
        ;;
      --user)
        user="$2"
        shift
        ;;
      --help|-h)
        usage
        return 0
        ;;
      --)
        shift
        extra_packages=("$@")
        break
        ;;
      https://github.com/*|git@github.com:*)
        repo_url="$1"
        ;;
      *)
        if [[ -z "$container" ]]; then
          container="$1"
        elif is_github_token "$1"; then
          github_token="$1"
        else
          echo "Unexpected argument: $1" >&2
          usage >&2
          exit 1
        fi
        ;;
    esac
    shift
  done

  if [[ -z "$container" ]]; then
    usage >&2
    exit 1
  fi

  parse_container_arg "$container"
  container="$PARSED_CONTAINER"
  remote="$PARSED_REMOTE"

  local home
  home="$(user_home "$user")"

  local repo_root
  repo_root="$(script_repo_root)"

  local image_path
  image_path="$(build_headless_image "$repo_root")"
  sync_headless_image "$remote" "$image_path"

  local target_container
  target_container="$(container_ref "$container" "$remote")"
  launch_container "$target_container" "$container" "$remote" "$user" "$home"

  if [[ "$prepare" != true ]]; then
    echo "Launched Incus container '$target_container'."
    return 0
  fi

  if [[ -z "$repo_path" ]]; then
    repo_path="$(current_repo_path_or_empty)"
  fi

  if [[ -n "$repo_path" && -z "$repo_url" ]]; then
    repo_url="$(normalize_repo_url "$(detect_repo_url "$repo_path")")"
  else
    repo_url="$(normalize_repo_url "$repo_url")"
  fi

  if [[ "$session_scope" == "repo" && -z "$repo_path" ]]; then
    if [[ "$session_scope_explicit" == true ]]; then
      echo "Repo-scoped sessions require a repo path. Run from inside the repo or pass --path." >&2
      exit 1
    fi
    session_scope="none"
  fi

  prepare_container \
    "$target_container" \
    "$user" \
    "$home" \
    "$mode" \
    "$github_token" \
    "$repo_url" \
    "$repo_path" \
    "$session_scope" \
    "${extra_packages[@]}"
}

usage() {
  cat <<'EOF'
Usage: incus-dev <name|remote:name> [options] [github-token] [repo-url] [-- packages...]

Builds the headless image, uploads it when the target remote is stale,
launches the container, and optionally prepares it.

Arguments:
  name          Container name, or remote:name
  github-token  Optional GitHub PAT for git credential store
  repo-url      Optional GitHub repo URL to clone
  packages      Nixpkgs packages to install via nix profile (after --)

Options:
  --no-prepare      Launch only; skip credentials, repo, sessions, packages
  --copy            Copy credentials into container (default)
  --mount-rw        Bind-mount credentials from host
  --path PATH       Mirror this absolute local repo path inside the container
  --no-sessions     Skip copying agent session state
  --repo-sessions   Copy Claude/Codex/Pi sessions for the current repo
  --all-sessions    Copy all Claude/Codex/Pi sessions
  --user USER       Container user (default: thrawny)

If run inside a git repo, preparation clones that repo into the same absolute
path in the container and copies repo-scoped sessions by default.

Examples:
  incus-dev kf1-go
  incus-dev local:kf1-go
  incus-dev kanel-devbox:kf1-go
  incus-dev kf1-go --no-prepare
  incus-dev kf1-go --path /home/thrawny/dotfiles
  incus-dev kf1-go github_pat_xxx https://github.com/org/repo -- mosquitto upx
EOF
}

script_repo_root() {
  local script_path
  script_path="$(readlink -f "${BASH_SOURCE[0]}")"
  dirname "$(dirname "$script_path")"
}

parse_container_arg() {
  local value="$1"

  PARSED_REMOTE="local"
  PARSED_CONTAINER="$value"

  if [[ "$value" == *:* ]]; then
    PARSED_REMOTE="${value%%:*}"
    PARSED_CONTAINER="${value#*:}"
  fi

  if [[ -z "$PARSED_REMOTE" || -z "$PARSED_CONTAINER" ]]; then
    echo "Invalid container name: $value" >&2
    exit 1
  fi
}

user_home() {
  local user="$1"

  if [[ "$user" == "root" ]]; then
    printf '/root\n'
  else
    printf '/home/%s\n' "$user"
  fi
}

container_ref() {
  local container="$1" remote="$2"
  printf '%s%s\n' "${remote:+$remote:}" "$container"
}

remote_ref() {
  local remote="$1"
  printf '%s:\n' "$remote"
}

build_headless_image() {
  local repo_root="$1"

  nix build "$repo_root/nix#nixosConfigurations.headless.config.system.build.images.incus" \
    --no-link \
    --print-out-paths
}

image_property() {
  local image_ref="$1" key="$2"

  incus image show "$image_ref" 2>/dev/null | awk -v key="$key:" '
    /^properties:/ { in_props = 1; next }
    in_props && /^[^[:space:]]/ { in_props = 0 }
    in_props {
      sub(/^[[:space:]]+/, "", $0)
      if (index($0, key) == 1) {
        sub("^" key "[[:space:]]*", "", $0)
        print
        exit
      }
    }
  '
}

sync_headless_image() {
  local remote="$1" image_path="$2"
  local image_ref
  image_ref="$(container_ref headless "$remote")"

  local current_path
  current_path="$(image_property "$image_ref" nix_store_path || true)"

  if [[ "$current_path" == "$image_path" ]]; then
    echo "Image '$image_ref' already up to date."
    return 0
  fi

  echo "Importing headless image to '$remote'."
  incus image import \
    "$image_path/metadata.tar.xz" \
    "$image_path/rootfs.tar.zst" \
    "$(remote_ref "$remote")" \
    nix_store_path="$image_path" \
    --alias headless \
    --reuse
}

launch_container() {
  local target_container="$1" name="$2" remote="$3" user="$4" home="$5"
  local image_ref
  image_ref="$(container_ref headless "$remote")"

  incus launch "$image_ref" "$target_container" -c security.nesting=true

  local label
  label="incus:$remote:$name"
  wait_for_user_shell "$target_container" "$user" "$home"
  write_container_label "$target_container" "$user" "$home" "$label"
}

wait_for_user_shell() {
  local container="$1" user="$2" home="$3"

  while ! container_shell_as_user "$container" "$user" "$home" "true" >/dev/null 2>&1; do
    sleep 0.5
  done
}

write_container_label() {
  local container="$1" user="$2" home="$3" label="$4"

  incus exec "$container" -- env \
    HOME="$home" \
    USER="$user" \
    LOGNAME="$user" \
    INCUS_CONTAINER_VALUE="$label" \
    runuser -u "$user" -- sh -lc 'printf "%s\n" "export INCUS_CONTAINER=\"$INCUS_CONTAINER_VALUE\"" > ~/.zsh.local'
}

prepare_container() {
  local container="$1" user="$2" home="$3" mode="$4" github_token="$5" repo_url="$6" repo_path="$7" session_scope="$8"
  shift 8
  local -a extra_packages=("$@")

  local -a host_files=(
    "$HOME/.claude/.credentials.json"
    "$HOME/.pi/agent/auth.json"
    "$HOME/.codex/auth.json"
  )
  local -a dest_files=(
    "$home/.claude/.credentials.json"
    "$home/.pi/agent/auth.json"
    "$home/.codex/auth.json"
  )
  local -a device_names=(
    "claude-credentials"
    "pi-auth"
    "codex-auth"
  )

  incus info "$container" >/dev/null
  ensure_dirs "$container" "$user" "$home"

  local i
  for i in "${!host_files[@]}"; do
    if [[ ! -f "${host_files[$i]}" ]]; then
      echo "Missing host file: ${host_files[$i]}" >&2
      exit 1
    fi

    if [[ "$mode" == "mount" ]]; then
      mount_file "$container" "${device_names[$i]}" "${host_files[$i]}" "${dest_files[$i]}"
    else
      copy_file "$container" "$user" "${host_files[$i]}" "${dest_files[$i]}"
    fi
  done

  setup_git_credentials "$container" "$user" "$home" "$github_token"

  if [[ -n "$repo_url" ]]; then
    clone_repo "$container" "$user" "$home" "$repo_url" "$repo_path"
  elif [[ -n "$repo_path" ]]; then
    ensure_repo_parent "$container" "$user" "$repo_path"
    if ! incus exec "$container" -- test -d "$repo_path"; then
      echo "Warning: repo path does not exist in container and no repo URL was supplied or detected: $repo_path" >&2
    fi
  fi

  if [[ -n "$repo_path" ]]; then
    set_repo_git_identity "$container" "$user" "$home" "$repo_path"
  fi

  if [[ "$session_scope" != "none" ]]; then
    copy_sessions "$container" "$user" "$home" "$session_scope" "$repo_path"
  fi

  if [[ ${#extra_packages[@]} -gt 0 ]]; then
    install_packages "$container" "$user" "$home" "${extra_packages[@]}"
  fi

  echo "Prepared Incus container '$container' for user '$user' via mode '$mode' (sessions: $session_scope)."
}

is_github_token() {
  case "$1" in
    ghp_*|gho_*|ghu_*|ghs_*|ghr_*|github_pat_*|gh_pat_*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

resolve_host_path() {
  local path="$1"

  if [[ -z "$path" ]]; then
    echo "Missing required path argument." >&2
    exit 1
  fi
  if [[ ! -d "$path" ]]; then
    echo "Path does not exist or is not a directory: $path" >&2
    exit 1
  fi

  (cd "$path" && pwd -P)
}

current_repo_path_or_empty() {
  git rev-parse --show-toplevel 2>/dev/null || true
}

detect_repo_url() {
  local repo_path="$1"

  [[ -n "$repo_path" ]] || return 0
  git -C "$repo_path" remote get-url origin 2>/dev/null || true
}

normalize_repo_url() {
  local url="$1"

  case "$url" in
    git@github.com:*)
      printf 'https://github.com/%s\n' "${url#git@github.com:}"
      ;;
    *)
      printf '%s\n' "$url"
      ;;
  esac
}

claude_project_slug() {
  local repo_path="$1"
  local trimmed="${repo_path#/}"
  printf -- '-%s\n' "${trimmed//\//-}"
}

pi_session_slug() {
  local repo_path="$1"
  local trimmed="${repo_path#/}"
  printf -- '--%s--\n' "${trimmed//\//-}"
}

ensure_dirs() {
  local container="$1" user="$2" home="$3"

  incus exec "$container" -- mkdir -p \
    "$home/.claude" \
    "$home/.pi/agent" \
    "$home/.codex"

  if [[ "$user" != "root" ]]; then
    local owner_spec
    owner_spec="$(container_owner_spec "$container" "$user")"
    incus exec "$container" -- chown -R "$owner_spec" \
      "$home/.claude" \
      "$home/.pi" \
      "$home/.codex"
  fi
}

copy_file() {
  local container="$1" user="$2" src="$3" dest="$4"

  incus file push -p "$src" "$(container_file_target "$container" "$dest")"

  if [[ "$user" != "root" ]]; then
    local owner_spec
    owner_spec="$(container_owner_spec "$container" "$user")"
    incus exec "$container" -- chown "$owner_spec" "$dest"
  fi
}

copy_dir() {
  local container="$1" user="$2" src="$3" dest="$4"

  [[ -d "$src" ]] || return 0

  incus exec "$container" -- mkdir -p "$(dirname "$dest")"
  tar -C "$(dirname "$src")" -cf - -- "$(basename "$src")" \
    | incus exec "$container" -- tar -C "$(dirname "$dest")" -xf -

  if [[ "$user" != "root" ]]; then
    local owner_spec
    owner_spec="$(container_owner_spec "$container" "$user")"
    incus exec "$container" -- chown -R "$owner_spec" "$dest"
  fi
}

container_owner_spec() {
  local container="$1" user="$2" group
  group="$(incus exec "$container" -- id -gn "$user")"
  printf '%s:%s\n' "$user" "$group"
}

container_file_target() {
  local container="$1" dest="$2"
  printf '%s%s\n' "$container" "$dest"
}

container_shell_as_user() {
  local container="$1" user="$2" home="$3" command="$4"

  if [[ "$user" == "root" ]]; then
    incus exec "$container" -- env HOME="$home" USER=root LOGNAME=root sh -lc "$command"
  else
    incus exec "$container" -- env HOME="$home" USER="$user" LOGNAME="$user" \
      runuser -u "$user" -- sh -lc "$command"
  fi
}

setup_git_credentials() {
  local container="$1" user="$2" home="$3" token="$4"
  local gitconfig_local="$home/.gitconfig.local"

  if ! incus exec "$container" -- test -f "$gitconfig_local"; then
    local tmpfile
    tmpfile="$(mktemp)"
    cat > "$tmpfile" <<'EOF'
[credential]
	helper = store
EOF
    copy_file "$container" "$user" "$tmpfile" "$gitconfig_local"
    rm -f "$tmpfile"
  fi

  if [[ -n "$token" ]]; then
    local tmpfile
    tmpfile="$(mktemp)"
    printf 'https://x-access-token:%s@github.com\n' "$token" > "$tmpfile"
    copy_file "$container" "$user" "$tmpfile" "$home/.git-credentials"
    rm -f "$tmpfile"
    incus exec "$container" -- chmod 600 "$home/.git-credentials"
  fi
}

set_repo_git_identity() {
  local container="$1" user="$2" home="$3" repo_path="$4"
  local name email

  name="${GIT_AUTHOR_NAME:-$(git config user.name 2>/dev/null || true)}"
  email="${GIT_AUTHOR_EMAIL:-$(git config user.email 2>/dev/null || true)}"

  [[ -n "$name" && -n "$email" ]] || return 0

  if incus exec "$container" -- test -d "$repo_path/.git"; then
    container_shell_as_user "$container" "$user" "$home" \
      "git -C '$repo_path' config user.name '$name' && git -C '$repo_path' config user.email '$email'"
    echo "Set git identity in $repo_path: $name <$email>"
  fi
}

ensure_repo_parent() {
  local container="$1" user="$2" repo_path="$3"

  [[ -n "$repo_path" ]] || return 0

  incus exec "$container" -- mkdir -p "$(dirname "$repo_path")"
  if [[ "$user" != "root" ]]; then
    incus exec "$container" -- chown "$(container_owner_spec "$container" "$user")" "$(dirname "$repo_path")"
  fi
}

clone_repo() {
  local container="$1" user="$2" home="$3" url="$4" repo_path="$5"
  local repo_name dest_path

  repo_name="$(basename "$url" .git)"
  if [[ -n "$repo_path" ]]; then
    dest_path="$repo_path"
  else
    dest_path="$home/code/$repo_name"
  fi

  if incus exec "$container" -- test -d "$dest_path"; then
    echo "Repo already present: $dest_path"
  else
    ensure_repo_parent "$container" "$user" "$dest_path"
    container_shell_as_user "$container" "$user" "$home" \
      "git clone --depth 1 '$url' '$dest_path' && cd '$dest_path' && git config remote.origin.fetch '+refs/heads/*:refs/remotes/origin/*'"
  fi
}

copy_sessions() {
  local container="$1" user="$2" home="$3" scope="$4" repo_path="$5"

  case "$scope" in
    repo)
      [[ -n "$repo_path" ]] || {
        echo "Repo-scoped sessions require a repo path. Run from inside the repo or pass --path." >&2
        exit 1
      }
      echo "Copying agent sessions for repo: $repo_path"
      copy_repo_claude_sessions "$container" "$user" "$home" "$repo_path"
      copy_repo_codex_sessions "$container" "$user" "$home" "$repo_path"
      copy_repo_pi_sessions "$container" "$user" "$home" "$repo_path"
      ;;
    all)
      echo "Copying all agent sessions."
      copy_all_claude_sessions "$container" "$user" "$home"
      copy_all_codex_sessions "$container" "$user" "$home"
      copy_all_pi_sessions "$container" "$user" "$home"
      ;;
    *)
      echo "Unknown session scope: $scope" >&2
      exit 1
      ;;
  esac
}

copy_repo_claude_sessions() {
  local container="$1" user="$2" home="$3" repo_path="$4"
  local project_slug project_dir
  local session_file session_id

  project_slug="$(claude_project_slug "$repo_path")"
  project_dir="$HOME/.claude/projects/$project_slug"

  copy_dir "$container" "$user" "$project_dir" "$home/.claude/projects/$project_slug"
  copy_dir "$container" "$user" "$HOME/.claude/sessions" "$home/.claude/sessions"

  for session_file in "$project_dir"/*.jsonl; do
    [[ -f "$session_file" ]] || continue
    session_id="$(basename "$session_file" .jsonl)"
    copy_dir "$container" "$user" "$HOME/.claude/file-history/$session_id" "$home/.claude/file-history/$session_id"
  done
}

copy_repo_codex_sessions() {
  local container="$1" user="$2" home="$3" repo_path="$4"
  local file relative metadata_file
  local -a session_files=()

  mapfile -t session_files < <(
    rg -l --fixed-strings -g '*.jsonl' "\"cwd\":\"$repo_path\"" "$HOME/.codex/sessions" 2>/dev/null || true
  )

  for file in "${session_files[@]}"; do
    relative="${file#"$HOME/.codex/sessions/"}"
    copy_file "$container" "$user" "$file" "$home/.codex/sessions/$relative"
  done

  for metadata_file in \
    "$HOME/.codex/session_index.jsonl" \
    "$HOME/.codex/history.jsonl" \
    "$HOME"/.codex/state_*.sqlite* \
    "$HOME"/.codex/logs_*.sqlite*
  do
    [[ -f "$metadata_file" ]] || continue
    copy_file "$container" "$user" "$metadata_file" "$home/.codex/$(basename "$metadata_file")"
  done
}

copy_repo_pi_sessions() {
  local container="$1" user="$2" home="$3" repo_path="$4"
  local slug

  slug="$(pi_session_slug "$repo_path")"
  copy_dir "$container" "$user" "$HOME/.pi/agent/sessions/$slug" "$home/.pi/agent/sessions/$slug"
}

copy_all_claude_sessions() {
  local container="$1" user="$2" home="$3"

  copy_dir "$container" "$user" "$HOME/.claude/projects" "$home/.claude/projects"
  copy_dir "$container" "$user" "$HOME/.claude/file-history" "$home/.claude/file-history"
  copy_dir "$container" "$user" "$HOME/.claude/session-env" "$home/.claude/session-env"
  copy_dir "$container" "$user" "$HOME/.claude/shell-snapshots" "$home/.claude/shell-snapshots"
  copy_dir "$container" "$user" "$HOME/.claude/sessions" "$home/.claude/sessions"
}

copy_all_codex_sessions() {
  local container="$1" user="$2" home="$3"
  local metadata_file

  copy_dir "$container" "$user" "$HOME/.codex/sessions" "$home/.codex/sessions"
  for metadata_file in \
    "$HOME/.codex/session_index.jsonl" \
    "$HOME/.codex/history.jsonl" \
    "$HOME"/.codex/state_*.sqlite* \
    "$HOME"/.codex/logs_*.sqlite*
  do
    [[ -f "$metadata_file" ]] || continue
    copy_file "$container" "$user" "$metadata_file" "$home/.codex/$(basename "$metadata_file")"
  done
}

copy_all_pi_sessions() {
  local container="$1" user="$2" home="$3"

  copy_dir "$container" "$user" "$HOME/.pi/agent/sessions" "$home/.pi/agent/sessions"
}

install_packages() {
  local container="$1" user="$2" home="$3"
  shift 3
  local -a pkgs=()
  local pkg

  for pkg in "$@"; do
    pkgs+=("nixpkgs#${pkg}")
  done

  echo "Installing packages: $*"
  container_shell_as_user "$container" "$user" "$home" "nix profile add ${pkgs[*]}"
}

mount_file() {
  local container="$1" device_name="$2" src="$3" dest="$4"

  incus config device remove "$container" "$device_name" >/dev/null 2>&1 || true
  incus config device add "$container" "$device_name" disk \
    source="$src" \
    path="$dest"
}

main "$@"
