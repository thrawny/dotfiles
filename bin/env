#!/usr/bin/env python3
import os
import re
import sys
from pathlib import Path
from typing import NoReturn

# pyright: basic

ASSIGNMENT_RE = re.compile(r"^[A-Za-z_][A-Za-z0-9_]*=")
REDACT_NAME_PARTS = (
    "API_KEY",
    "API_TOKEN",
    "AUTH",
    "CREDENTIAL",
    "DATABASE_URL",
    "DB_URL",
    "KEY",
    "PASSWORD",
    "PRIVATE",
    "SECRET",
    "TOKEN",
)
ALWAYS_REDACT_NAMES = {
    "AWS_ACCESS_KEY_ID",
    "AWS_SECRET_ACCESS_KEY",
    "AWS_SESSION_TOKEN",
    "SANDBOX_REDACT_ENV_NAMES",
}


def find_real_binary(name: str) -> str:
    current = Path(sys.argv[0]).resolve()

    for directory in os.environ.get("PATH", "").split(os.pathsep):
        if not directory:
            continue

        candidate = Path(directory) / name
        try:
            if candidate.resolve() == current:
                continue
            if candidate.is_file() and os.access(candidate, os.X_OK):
                return str(candidate)
        except OSError:
            continue

    for directory in ("/run/current-system/sw/bin", "/usr/bin", "/bin"):
        candidate = Path(directory) / name
        try:
            if candidate.resolve() == current:
                continue
            if candidate.is_file() and os.access(candidate, os.X_OK):
                return str(candidate)
        except OSError:
            continue

    print(f"{name}: could not find real {name} binary", file=sys.stderr)
    sys.exit(127)


def exec_real_binary(name: str) -> NoReturn:
    real_binary = find_real_binary(name)
    os.execv(real_binary, [real_binary, *sys.argv[1:]])


def parse_env_print_request(argv: list[str]):
    null_output = False
    ignore_environment = False
    unset_names: list[str] = []
    assignments: dict[str, str] = {}
    parsing_options = True
    index = 0

    while index < len(argv):
        arg = argv[index]

        if parsing_options and arg == "--":
            parsing_options = False
            index += 1
            continue

        if parsing_options:
            if arg in ("-0", "--null"):
                null_output = True
                index += 1
                continue
            if arg in ("-i", "--ignore-environment", "-"):
                ignore_environment = True
                index += 1
                continue
            if arg in ("-u", "--unset"):
                if index + 1 >= len(argv):
                    return None
                unset_names.append(argv[index + 1])
                index += 2
                continue
            if arg.startswith("--unset="):
                unset_names.append(arg.split("=", 1)[1])
                index += 1
                continue
            if arg.startswith("-"):
                return None

        if ASSIGNMENT_RE.match(arg):
            name, value = arg.split("=", 1)
            assignments[name] = value
            index += 1
            continue

        return None

    return null_output, ignore_environment, unset_names, assignments


def parse_printenv_request(argv: list[str]):
    null_output = False
    names: list[str] = []
    parsing_options = True

    for arg in argv:
        if parsing_options and arg == "--":
            parsing_options = False
            continue

        if parsing_options:
            if arg in ("-0", "--null"):
                null_output = True
                continue
            if arg.startswith("-"):
                return None

        names.append(arg)

    return null_output, names


def secret_names_from_environment() -> set[str]:
    names = set(ALWAYS_REDACT_NAMES)
    raw_names = os.environ.get("SANDBOX_REDACT_ENV_NAMES", "")
    for name in re.split(r"[\s,]+", raw_names):
        if name:
            names.add(name)
    return names


def should_redact(name: str, secret_names: set[str]) -> bool:
    upper_name = name.upper()
    return name in secret_names or any(part in upper_name for part in REDACT_NAME_PARTS)


def redact(value: str) -> str:
    if value == "":
        return "REDACTED_EMPTY"
    if len(value) <= 4:
        return "REDACTED_PRESENT"
    return f"REDACTED_{value[-4:]}"


def redacted_value(name: str, value: str, secret_names: set[str]) -> str:
    if should_redact(name, secret_names):
        return redact(value)
    return value


def run_env() -> None:
    if os.environ.get("SANDBOX") != "1":
        exec_real_binary("env")

    request = parse_env_print_request(sys.argv[1:])
    if request is None:
        exec_real_binary("env")

    null_output, ignore_environment, unset_names, assignments = request
    env = {} if ignore_environment else dict(os.environ)
    for name in unset_names:
        env.pop(name, None)
    env.update(assignments)

    secret_names = secret_names_from_environment()
    separator = "\0" if null_output else "\n"

    for name, value in env.items():
        sys.stdout.write(
            f"{name}={redacted_value(name, value, secret_names)}{separator}"
        )


def run_printenv() -> None:
    if os.environ.get("SANDBOX") != "1":
        exec_real_binary("printenv")

    request = parse_printenv_request(sys.argv[1:])
    if request is None:
        exec_real_binary("printenv")

    null_output, names = request
    env = dict(os.environ)
    secret_names = secret_names_from_environment()
    separator = "\0" if null_output else "\n"

    if not names:
        for name, value in env.items():
            sys.stdout.write(
                f"{name}={redacted_value(name, value, secret_names)}{separator}"
            )
        return

    missing = False
    for name in names:
        value = env.get(name)
        if value is None:
            missing = True
            continue
        sys.stdout.write(f"{redacted_value(name, value, secret_names)}{separator}")

    if missing:
        sys.exit(1)


def main() -> None:
    program_name = Path(sys.argv[0]).name
    if program_name == "printenv":
        run_printenv()
    else:
        run_env()


if __name__ == "__main__":
    main()
