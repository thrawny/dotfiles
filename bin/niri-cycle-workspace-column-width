#!/usr/bin/env bash

[[ "${TRACE}" ]] && set -x
set -euo pipefail

usage() {
  echo "Usage: niri-cycle-workspace-column-width [<proportion> ...]" >&2
  echo "Examples:" >&2
  echo "  niri-cycle-workspace-column-width        # flip 0.5 <-> 1/3 based on the current workspace" >&2
  echo "  niri-cycle-workspace-column-width 0.5 1/3 1" >&2
}

main() {
  local -a presets
  if [[ "$#" -eq 0 ]]; then
    presets=(0.5 1/3)
  else
    presets=("$@")
  fi

  if [[ "${#presets[@]}" -eq 0 ]]; then
    usage
    exit 1
  fi

  niri-resize-workspace-columns --toggle "${presets[@]}"
}

main "$@"
