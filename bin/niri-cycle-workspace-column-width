#!/usr/bin/env bash

[[ "${TRACE}" ]] && set -x
set -euo pipefail

usage() {
  echo "Usage: niri-cycle-workspace-column-width [<proportion> ...]" >&2
  echo "Examples:" >&2
  echo "  niri-cycle-workspace-column-width        # cycle 0.5 <-> 1/3" >&2
  echo "  niri-cycle-workspace-column-width 0.5 1/3 1" >&2
}

main() {
  local -a presets
  if [[ "$#" -eq 0 ]]; then
    presets=(0.5 1/3)
  else
    presets=("$@")
  fi

  if [[ "${#presets[@]}" -eq 0 ]]; then
    usage
    exit 1
  fi

  local state_dir state_file current_index next_index
  state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/niri"
  state_file="$state_dir/cycle-workspace-column-width"
  mkdir -p "$state_dir"

  current_index=-1
  if [[ -f "$state_file" ]]; then
    current_index=$(<"$state_file")
  fi

  if [[ ! "$current_index" =~ ^-?[0-9]+$ ]]; then
    current_index=-1
  fi

  next_index=$(( (current_index + 1 + ${#presets[@]}) % ${#presets[@]} ))
  printf '%s\n' "$next_index" > "$state_file"

  niri-resize-workspace-columns "${presets[$next_index]}"
}

main "$@"
