#!/usr/bin/env bash

[[ "${TRACE:-}" ]] && set -x
set -euo pipefail
shopt -s nullglob

main() {
  local container=""
  local user="thrawny"
  local repo_path=""
  local dry_run=false
  local force=false
  local agent="all"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --path)
        repo_path="$(resolve_host_path "$2")"
        shift
        ;;
      --user)
        user="$2"
        shift
        ;;
      --dry-run|-n)
        dry_run=true
        ;;
      --force)
        force=true
        ;;
      --agent)
        agent="$2"
        shift
        ;;
      --pi)
        agent="pi"
        ;;
      --codex)
        agent="codex"
        ;;
      --all)
        agent="all"
        ;;
      --help|-h)
        usage
        return 0
        ;;
      *)
        if [[ -z "$container" ]]; then
          container="$1"
        else
          echo "Unexpected argument: $1" >&2
          usage >&2
          exit 1
        fi
        ;;
    esac
    shift
  done

  if [[ -z "$container" ]]; then
    usage >&2
    exit 1
  fi

  if [[ -z "$repo_path" ]]; then
    repo_path="$(current_repo_path_or_empty)"
  fi
  if [[ -z "$repo_path" ]]; then
    echo "Could not detect repo path. Run from inside a git repo or pass --path." >&2
    exit 1
  fi

  case "$agent" in
    pi|codex|all) ;;
    *) echo "Invalid --agent value: $agent (expected pi, codex, or all)" >&2; exit 1 ;;
  esac

  local home tmpdir
  home="$(user_home "$user")"
  tmpdir="$(mktemp -d)"
  trap 'rm -rf "${tmpdir:-}"' EXIT

  incus info "$container" >/dev/null

  [[ "$dry_run" == true ]] && echo "Dry run: no files will be changed"

  if [[ "$agent" == "pi" || "$agent" == "all" ]]; then
    pull_pi_sessions "$container" "$home" "$repo_path" "$tmpdir" "$dry_run" "$force"
  fi
  if [[ "$agent" == "codex" || "$agent" == "all" ]]; then
    pull_codex_sessions "$container" "$home" "$repo_path" "$tmpdir" "$dry_run" "$force"
  fi
}

usage() {
  cat <<'EOF'
Usage: incus-pull-pi-sessions <container|remote:container> [options]

Pull repo-scoped Pi and/or Codex session JSONL files from an Incus container back
to the host. Remote sessions are imported as cloned local sessions with fresh
session IDs and friendly names like remote-session-kf1-go-6fb4034e-2026-04-27.
Identical remote files already present locally are skipped unless --force is used.

Options:
  --path PATH    Repo path whose Pi session slug should be synced
                 (default: current git repo root)
  --user USER    Container user (default: thrawny)
  --agent AGENT  Agent sessions to pull: pi, codex, or all (default: all)
  --pi           Pull only Pi sessions
  --codex        Pull only Codex sessions
  --all          Pull Pi and Codex sessions (default)
  --dry-run, -n  Show what would happen without changing local files
  --force        Clone even when an identical local file already exists
  --help, -h     Show this help

Examples:
  incus-pull-pi-sessions kanel-devbox:kf1-go
  incus-pull-pi-sessions kanel-devbox:kf1-go --path /home/thrawny/work/kanel/code/kf1-go
  incus-pull-pi-sessions kanel-devbox:kf1-go --dry-run
EOF
}

resolve_host_path() {
  local path="$1"
  if [[ -z "$path" ]]; then
    echo "Missing required path argument." >&2
    exit 1
  fi
  if [[ ! -d "$path" ]]; then
    echo "Path does not exist or is not a directory: $path" >&2
    exit 1
  fi
  (cd "$path" && pwd -P)
}

current_repo_path_or_empty() {
  git rev-parse --show-toplevel 2>/dev/null || true
}

user_home() {
  local user="$1"
  if [[ "$user" == "root" ]]; then
    printf '/root\n'
  else
    printf '/home/%s\n' "$user"
  fi
}

pi_session_slug() {
  local repo_path="$1"
  local trimmed="${repo_path#/}"
  printf -- '--%s--\n' "${trimmed//\//-}"
}

pull_pi_sessions() {
  local container="$1" home="$2" repo_path="$3" tmpdir="$4" dry_run="$5" force="$6"
  local slug remote_dir local_dir
  slug="$(pi_session_slug "$repo_path")"
  remote_dir="$home/.pi/agent/sessions/$slug"
  local_dir="$HOME/.pi/agent/sessions/$slug"

  if ! incus exec "$container" -- test -d "$remote_dir"; then
    echo "No remote Pi session directory: $container:$remote_dir"
    return 0
  fi

  mkdir -p "$local_dir"
  echo "Pulling Pi sessions from $container:$remote_dir"
  echo "Merging into $local_dir"

  local -a remote_files=()
  mapfile -t remote_files < <(
    incus exec "$container" -- find "$remote_dir" -maxdepth 1 -type f -name '*.jsonl' -printf '%f\n' | sort
  )

  local name remote_tmp local_file
  for name in "${remote_files[@]}"; do
    remote_tmp="$tmpdir/pi-$name"
    local_file="$local_dir/$name"
    incus file pull "$container$remote_dir/$name" "$remote_tmp" >/dev/null
    merge_session_file "$container" "pi" "$remote_tmp" "$local_file" "$local_dir" "$dry_run" "$force"
  done
}

pull_codex_sessions() {
  local container="$1" home="$2" repo_path="$3" tmpdir="$4" dry_run="$5" force="$6"
  local remote_root="$home/.codex/sessions"
  local local_root="$HOME/.codex/sessions"

  if ! incus exec "$container" -- test -d "$remote_root"; then
    echo "No remote Codex session directory: $container:$remote_root"
    return 0
  fi

  mkdir -p "$local_root"
  echo "Pulling Codex sessions from $container:$remote_root for cwd $repo_path"
  echo "Merging into $local_root"

  local -a remote_files=()
  mapfile -t remote_files < <(
    incus exec "$container" -- sh -c 'find "$1" -type f -name "*.jsonl" -print0 | xargs -0 grep -l -F "\"cwd\":\"$2\"" 2>/dev/null | sort' sh "$remote_root" "$repo_path"
  )

  local remote_file rel name remote_tmp local_dir local_file
  for remote_file in "${remote_files[@]}"; do
    rel="${remote_file#$remote_root/}"
    name="$(basename "$rel")"
    remote_tmp="$tmpdir/codex-${name}"
    local_dir="$local_root/$(dirname "$rel")"
    local_file="$local_root/$rel"
    mkdir -p "$local_dir"
    incus file pull "$container$remote_file" "$remote_tmp" >/dev/null
    merge_session_file "$container" "codex" "$remote_tmp" "$local_file" "$local_dir" "$dry_run" "$force"
  done
}

merge_session_file() {
  local container="$1" agent="$2" remote_file="$3" local_file="$4" local_dir="$5" dry_run="$6" force="$7"
  local name
  name="$(basename "$local_file")"

  if [[ -e "$local_file" ]] && cmp -s "$remote_file" "$local_file" && [[ "$force" != true ]]; then
    echo "SKIP identical source already local: $name"
    return 0
  fi

  echo "CLONE remote $agent: $name"
  if [[ "$dry_run" != true ]]; then
    clone_remote_session "$container" "$agent" "$remote_file" "$local_dir"
  fi
}

clone_remote_session() {
  local container="$1" agent="$2" remote_file="$3" local_dir="$4"
  python3 - "$container" "$agent" "$remote_file" "$local_dir" <<'PY'
import json
import os
import pathlib
import re
import sys
import uuid
from datetime import datetime, timezone

container, agent, remote_file, local_dir = sys.argv[1:]
path = pathlib.Path(remote_file)
lines = path.read_text(encoding="utf-8").splitlines()
if not lines:
    raise SystemExit(f"Empty session file: {remote_file}")

header = json.loads(lines[0])
if agent == "codex":
    payload = header.setdefault("payload", {})
    old_id = str(payload.get("id") or "unknown")
else:
    old_id = str(header.get("id") or "unknown")

new_id = str(uuid.uuid4())
now = datetime.now(timezone.utc)
now_iso = now.isoformat(timespec="milliseconds").replace("+00:00", "Z")
file_ts = now_iso.replace(":", "-").replace(".", "-")

container_name = container.split(":")[-1]
safe_container = re.sub(r"[^A-Za-z0-9_.-]+", "-", container_name).strip("-") or "container"
old_short = old_id.split("-")[0][:8] if old_id != "unknown" else "unknown"
date = now.date().isoformat()
session_name = f"remote-session-{safe_container}-{old_short}-{date}"

if agent == "codex":
    header["timestamp"] = now_iso
    header["payload"]["id"] = new_id
    header["payload"]["timestamp"] = now_iso
    header["payload"]["parent_session"] = str(path.name)
    out_lines = [json.dumps(header, separators=(",", ":"), ensure_ascii=False)]
    out_lines.extend(lines[1:])
    out_name = f"rollout-{now.strftime('%Y-%m-%dT%H-%M-%S')}-{new_id}.jsonl"
else:
    header["id"] = new_id
    header["timestamp"] = now_iso
    header["parentSession"] = str(path.name)

    last_entry_id = None
    for line in lines[1:]:
        try:
            entry = json.loads(line)
        except json.JSONDecodeError:
            continue
        if entry.get("type") != "session" and entry.get("id"):
            last_entry_id = entry["id"]

    out_lines = [json.dumps(header, separators=(",", ":"), ensure_ascii=False)]
    out_lines.extend(lines[1:])
    if last_entry_id:
        out_lines.append(json.dumps({
            "type": "session_info",
            "id": uuid.uuid4().hex[:8],
            "parentId": last_entry_id,
            "timestamp": now_iso,
            "name": session_name,
        }, separators=(",", ":"), ensure_ascii=False))
    out_name = f"{file_ts}_{new_id}.jsonl"

out_path = pathlib.Path(local_dir) / out_name
out_path.write_text("\n".join(out_lines) + "\n", encoding="utf-8")
print(f"  wrote {out_path.name}")
print(f"  name  {session_name}")
PY
}

main "$@"
