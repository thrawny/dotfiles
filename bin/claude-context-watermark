#!/usr/bin/env bash
# PostToolUse hook: warn the model when context usage crosses a watermark.
#
# Reads the hook JSON on stdin, estimates current context occupancy from the
# last assistant usage block in the session transcript, and injects an
# additionalContext warning at each configured checkpoint so the model writes
# and then refreshes a session-scoped auto-handoff shortly before auto-compact
# fires. The companion SessionStart hook (claude-handoff-takeoff) injects that
# file back after compaction.
#
# Env:
#   CLAUDE_CODE_AUTO_COMPACT_WINDOW   token window to measure against (default 300000)
#   CLAUDE_CONTEXT_WATERMARK_PCTS     space/comma-separated checkpoints (default "85 88")
set -uo pipefail

main() {
  local input transcript session usage window pct thresholds threshold trigger_pct
  local state_dir state_file last_threshold handoff_dir

  input=$(cat) || return 0
  transcript=$(jq -r '.transcript_path // empty' <<<"$input" 2>/dev/null) || return 0
  session=$(jq -r '.session_id // empty' <<<"$input" 2>/dev/null) || return 0
  [[ -f "$transcript" && -n "$session" && "$session" != */* ]] || return 0

  # The last assistant message's usage block reflects the input size of the
  # most recent API call, i.e. current context occupancy. Zero-usage blocks
  # (compact boundaries, synthetic entries) are skipped.
  usage=$(
    tail -n 500 "$transcript" 2>/dev/null | jq -rs '
      [ .[]
        | select(.type == "assistant")
        | .message.usage
        | select(. != null and .input_tokens != null)
        | (.input_tokens
           + (.cache_read_input_tokens // 0)
           + (.cache_creation_input_tokens // 0)
           + (.output_tokens // 0))
        | select(. > 0)
      ]
      | last // empty
    ' 2>/dev/null
  ) || return 0
  [[ "$usage" =~ ^[0-9]+$ ]] || return 0

  window=${CLAUDE_CODE_AUTO_COMPACT_WINDOW:-300000}
  [[ "$window" =~ ^[1-9][0-9]*$ ]] || return 0
  pct=$((usage * 100 / window))

  # Warn at exact checkpoints rather than broad 10% bands. Claude reserves
  # headroom and can compact before 90%, so the defaults create at 85% and
  # refresh at 88%. If usage drops after compaction, reset for the next climb.
  thresholds=${CLAUDE_CONTEXT_WATERMARK_PCTS:-"85 88"}
  thresholds=${thresholds//,/ }

  state_dir=${TMPDIR:-/tmp}/claude-context-watermark
  mkdir -p "$state_dir" 2>/dev/null || return 0
  state_file=$state_dir/$session
  last_threshold=$(cat "$state_file" 2>/dev/null) || last_threshold=0
  [[ "$last_threshold" =~ ^[0-9]+$ ]] || last_threshold=0
  if ((pct + 20 < last_threshold)); then
    echo 0 >"$state_file" 2>/dev/null
    return 0
  fi

  trigger_pct=0
  for threshold in $thresholds; do
    [[ "$threshold" =~ ^[0-9]+$ ]] || continue
    ((threshold > 0 && threshold < 100)) || continue
    if ((pct >= threshold && threshold > last_threshold && threshold > trigger_pct)); then
      trigger_pct=$threshold
    fi
  done
  ((trigger_pct > 0)) || return 0
  echo "$trigger_pct" >"$state_file" 2>/dev/null

  handoff_dir=${XDG_STATE_HOME:-$HOME/.local/state}/claude/handoffs
  jq -n --arg ctx "Context usage is at ~${pct}% of the ${window}-token auto-compact window (crossed the ${trigger_pct}% handoff checkpoint). Write a session auto-handoff to ${handoff_dir}/${session}.md now (create the directory if needed), then continue the task. Include: the next goal; decisions made and why; paths of files touched; test/gate results and unresolved errors; anything deliberately left running (dev servers, background agents, acpx sessions); the immediate next action. Keep it under ~1000 tokens. This is separate from the manual handoff flow — do not touch any handoff.md in the repo." \
    '{hookSpecificOutput: {hookEventName: "PostToolUse", additionalContext: $ctx}}'
}

main
exit 0
