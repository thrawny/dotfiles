#!/usr/bin/env bash
# gauntlet-review — run Claude and Codex code reviews in parallel over the same
# scope and print both raw findings in delimited sections.
#
# Mechanical launcher only: the caller (the `gauntlet` skill) supplies the
# context brief and does all the judgment — dedupe, verify, fix, summarize.
#
# Usage:
#   gauntlet-review [--base <branch> | --uncommitted | --commit <sha>] [brief]
#   ... | gauntlet-review --uncommitted -      # read brief from stdin
#
# Scope defaults to the current branch vs origin's default branch
# (--uncommitted when on that branch). The brief is extra review context passed
# verbatim to both engines; omit it or
# pass '-' to read from stdin (empty is allowed).
#
# Graceful degradation: if one engine is unauthenticated or out of usage/quota,
# the script continues with the other and labels why. Exits 0 if at least one
# engine produced a result, non-zero only if both failed.
#
# Testable with stubs: put fake `claude`/`codex` earlier on PATH.
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
Usage: gauntlet-review [--base <branch> | --uncommitted | --commit <sha>] [brief]

Runs Claude (/code-review) and Codex (review) over the same scope in parallel
and prints both raw findings in delimited sections. The caller supplies the
brief and does the dedupe/verify/fix/summarize.
EOF
  exit "${1:-0}"
}

scope=""
scope_set=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --base) scope="--base $2"; scope_set=1; shift 2 ;;
    --uncommitted) scope="--uncommitted"; scope_set=1; shift ;;
    --commit) scope="--commit $2"; scope_set=1; shift 2 ;;
    -h | --help) usage 0 ;;
    --) shift; break ;;
    -) break ;; # stdin marker for the brief; handled below
    -*) echo "gauntlet-review: unknown option: $1" >&2; usage 1 ;;
    *) break ;;
  esac
done

# Auto-detect scope when none was given: current branch vs origin's default
# branch, or uncommitted changes when already on the corresponding local branch.
# Compare against the remote-tracking ref so a stale local branch does not add
# already-merged upstream changes to the review.
if [[ "$scope_set" -eq 0 ]]; then
  branch="$(git rev-parse --abbrev-ref HEAD)"
  default_ref="$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null || true)"
  default_ref="${default_ref:-origin/main}"
  default_branch="${default_ref#origin/}"
  if [[ "$branch" == "$default_branch" ]]; then scope="--uncommitted"; else scope="--base $default_ref"; fi
fi

# Brief: remaining arg, else stdin (when piped), else empty.
if [[ $# -gt 0 && "$1" != "-" ]]; then
  brief="$*"
elif [[ ! -t 0 ]]; then
  brief="$(cat)"
else
  brief=""
fi

# Describe the scope as prose. Both engines get it this way: Codex's review
# rejects a custom prompt alongside its --base/--uncommitted/--commit flags, so
# we let it (agentically) compute the diff from these instructions instead.
case "$scope" in
  --uncommitted) scope_desc="Review the uncommitted changes in the working tree (staged, unstaged, and untracked)." ;;
  "--base "*) base="${scope#--base }"; scope_desc="Review the changes on this branch relative to ${base}: the diff from 'git diff ${base}...HEAD'." ;;
  "--commit "*) sha="${scope#--commit }"; scope_desc="Review only the changes introduced by commit ${sha}: 'git diff ${sha}~1..${sha}'." ;;
esac

focus="Treat the context/brief above as intended behavior — do not flag intentional choices, pre-existing code, style, or speculative edge cases. Report only real correctness bugs and clear issues introduced by this change. Prefer precision over recall."

claude_prompt="/code-review ${scope_desc}

${brief}

${focus}
Report findings only: do NOT edit, comment, fix, or commit. For each finding output a line 'file:line — SEVERITY — one-line description', SEVERITY in high/medium/low."

codex_prompt="${scope_desc}

${brief}

${focus}"

claude_out="$(mktemp)"
codex_out="$(mktemp)"
codex_log="$(mktemp)"
trap 'rm -f "$claude_out" "$codex_out" "$codex_log"' EXIT

# Claude reviewer — prints findings to stdout, then exits. Pin every model
# selection surface to Opus 4.8: /code-review may spawn subagents or carry its
# own model override, and user/project settings may configure fallback models.
# Keep this policy hard-coded; gauntlet reviews must never consume Fable quota.
readonly claude_review_model="claude-opus-4-8"
readonly claude_review_settings='{"availableModels":["claude-opus-4-8"],"enforceAvailableModels":true,"fallbackModel":[]}'
CLAUDE_CODE_SUBAGENT_MODEL="$claude_review_model" \
ANTHROPIC_DEFAULT_OPUS_MODEL="$claude_review_model" \
  claude -p --model "$claude_review_model" --setting-sources "" \
    --settings "$claude_review_settings" --no-session-persistence \
    --permission-mode auto "$claude_prompt" >"$claude_out" 2>&1 &
claude_pid=$!

# Codex reviewer — scope is in the prompt (see above); high reasoning effort for
# a thorough review; writes its final answer to $codex_out, progress to $codex_log.
codex exec --ephemeral --color never --model gpt-5.6-sol -c model_reasoning_effort="high" -o "$codex_out" review "$codex_prompt" >"$codex_log" 2>&1 &
codex_pid=$!

if wait "$claude_pid"; then claude_status=0; else claude_status=$?; fi
if wait "$codex_pid"; then codex_status=0; else codex_status=$?; fi

# Classify a non-zero engine result so we can degrade gracefully and say why.
classify() {
  local status="$1" file="$2" txt
  [[ "$status" -eq 0 ]] && { echo "ok"; return; }
  txt="$(tr '[:upper:]' '[:lower:]' <"$file" 2>/dev/null || true)"
  case "$txt" in
    *"not logged in"* | *"log in"* | *"please login"* | *login* | *authenticat* | *unauthorized* | *"401"* | *"invalid api key"* | *"no credentials"* | *"logged out"* | *"session expired"*)
      echo "unavailable: not authenticated" ;;
    *"usage limit"* | *"rate limit"* | *"429"* | *quota* | *"ran out"* | *"out of credit"* | *credit* | *insufficient* | *"limit reached"* | *"too many requests"* | *upgrade*)
      echo "unavailable: usage/quota exhausted" ;;
    *)
      echo "failed (exit $status)" ;;
  esac
}

claude_state="$(classify "$claude_status" "$claude_out")"
codex_state="$(classify "$codex_status" "$codex_log")"

ok_count=0
[[ "$claude_status" -eq 0 ]] && ok_count=$((ok_count + 1))
[[ "$codex_status" -eq 0 ]] && ok_count=$((ok_count + 1))

# Graceful degradation: continue on whichever engine(s) succeeded; say why if one dropped.
if [[ "$ok_count" -eq 1 ]]; then
  if [[ "$claude_status" -eq 0 ]]; then
    printf 'NOTE: degraded to a single reviewer — codex %s. Proceeding with Claude only.\n\n' "$codex_state"
  else
    printf 'NOTE: degraded to a single reviewer — claude %s. Proceeding with Codex only.\n\n' "$claude_state"
  fi
elif [[ "$ok_count" -eq 0 ]]; then
  printf 'ERROR: no reviewer produced results — claude %s; codex %s\n' "$claude_state" "$codex_state" >&2
fi

printf '===== CLAUDE REVIEW [%s] =====\n' "$claude_state"
if [[ "$claude_status" -eq 0 ]]; then cat "$claude_out"; else tail -40 "$claude_out"; fi
printf '\n===== CODEX REVIEW [%s] =====\n' "$codex_state"
if [[ "$codex_status" -eq 0 ]]; then
  cat "$codex_out"
else
  # On failure, show codex's answer file if it wrote anything, plus the log tail
  # (codex diagnostics usually land on stderr -> $codex_log, but not always).
  if [[ -s "$codex_out" ]]; then cat "$codex_out"; fi
  printf '\n----- codex log tail -----\n'
  tail -40 "$codex_log"
fi

# Succeed if at least one engine produced a result; degrade gracefully otherwise.
[[ "$ok_count" -ge 1 ]]
