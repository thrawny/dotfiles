# Source nix-direnv if available (for non-NixOS systems)
# On NixOS, Home Manager's programs.direnv handles this
if [ -f "${XDG_DATA_HOME:-$HOME/.local/share}/nix-direnv/direnvrc" ]; then
    source "${XDG_DATA_HOME:-$HOME/.local/share}/nix-direnv/direnvrc"
fi

dotenv_if_exists .env
dotenv_if_exists .env.local

layout_uv() {
    if [[ -d ".venv" ]]; then
        VIRTUAL_ENV="$(pwd)/.venv"
    fi

    if [[ -z $VIRTUAL_ENV || ! -d $VIRTUAL_ENV ]]; then
        log_status "No uv project exists. Executing \`uv init\` to create one."
        uv init
        uv venv
        VIRTUAL_ENV="$(pwd)/.venv"
    fi

    PATH_add "$VIRTUAL_ENV/bin"
    export UV_ACTIVE=1
    export VIRTUAL_ENV
}
